g</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:type="dxa" w:w="5112"/><w:vAlign w:val="center"/></w:tcPr><w:p><w:r/><w:r><w:rPr><w:b w:val="0"/><w:sz w:val="18"/></w:rPr><w:t>image_cropper or custom crop UI</w:t></w:r></w:p></w:tc></w:tr><w:tr><w:tc><w:tcPr><w:tcW w:type="dxa" w:w="5112"/><w:vAlign w:val="center"/></w:tcPr><w:p><w:r/><w:r><w:rPr><w:b/><w:sz w:val="18"/></w:rPr><w:t>OCR</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:type="dxa" w:w="5112"/><w:vAlign w:val="center"/></w:tcPr><w:p><w:r/><w:r><w:rPr><w:b w:val="0"/><w:sz w:val="18"/></w:rPr><w:t>Google ML Kit Text Recognition or Tesseract-based OCR</w:t></w:r></w:p></w:tc></w:tr><w:tr><w:tc><w:tcPr><w:tcW w:type="dxa" w:w="5112"/><w:vAlign w:val="center"/></w:tcPr><w:p><w:r/><w:r><w:rPr><w:b/><w:sz w:val="18"/></w:rPr><w:t>PDF handling</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:type="dxa" w:w="5112"/><w:vAlign w:val="center"/></w:tcPr><w:p><w:r/><w:r><w:rPr><w:b w:val="0"/><w:sz w:val="18"/></w:rPr><w:t>pdfx, native PDF renderer, or other Flutter PDF tooling</w:t></w:r></w:p></w:tc></w:tr><w:tr><w:tc><w:tcPr><w:tcW w:type="dxa" w:w="5112"/><w:vAlign w:val="center"/></w:tcPr><w:p><w:r/><w:r><w:rPr><w:b/><w:sz w:val="18"/></w:rPr><w:t>Retrieval v1</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:type="dxa" w:w="5112"/><w:vAlign w:val="center"/></w:tcPr><w:p><w:r/><w:r><w:rPr><w:b w:val="0"/><w:sz w:val="18"/></w:rPr><w:t>Chunked keyword search and scoring</w:t></w:r></w:p></w:tc></w:tr><w:tr><w:tc><w:tcPr><w:tcW w:type="dxa" w:w="5112"/><w:vAlign w:val="center"/></w:tcPr><w:p><w:r/><w:r><w:rPr><w:b/><w:sz w:val="18"/></w:rPr><w:t>Retrieval v2</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:type="dxa" w:w="5112"/><w:vAlign w:val="center"/></w:tcPr><w:p><w:r/><w:r><w:rPr><w:b w:val="0"/><w:sz w:val="18"/></w:rPr><w:t>Local embeddings and vector search</w:t></w:r></w:p></w:tc></w:tr><w:tr><w:tc><w:tcPr><w:tcW w:type="dxa" w:w="5112"/><w:vAlign w:val="center"/></w:tcPr><w:p><w:r/><w:r><w:rPr><w:b/><w:sz w:val="18"/></w:rPr><w:t>Local AI v2/v3</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:type="dxa" w:w="5112"/><w:vAlign w:val="center"/></w:tcPr><w:p><w:r/><w:r><w:rPr><w:b w:val="0"/><w:sz w:val="18"/></w:rPr><w:t>llama.cpp / GGUF bridge if feasible on target devices</w:t></w:r></w:p></w:tc></w:tr></w:tbl><w:p/><w:p><w:pPr><w:pStyle w:val="Heading1"/></w:pPr><w:r><w:rPr><w:color w:val="184A78"/></w:rPr><w:t>9. Chat and Retrieval Logic</w:t></w:r></w:p><w:p><w:r><w:t>The first version should avoid overcomplicating AI. A practical MVP can answer questions by finding relevant text chunks and presenting them in a chat interface. This is easier to build and still demonstrates the core product idea.</w:t></w:r></w:p><w:p><w:r><w:rPr><w:b/></w:rPr><w:t xml:space="preserve">1.  </w:t></w:r><w:r><w:t>Split the extracted document text into chunks of around 500 to 1,000 characters.</w:t></w:r></w:p><w:p><w:r><w:rPr><w:b/></w:rPr><w:t xml:space="preserve">2.  </w:t></w:r><w:r><w:t>When the user asks a question, score each chunk using keyword overlap and simple ranking.</w:t></w:r></w:p><w:p><w:r><w:rPr><w:b/></w:rPr><w:t xml:space="preserve">3.  </w:t></w:r><w:r><w:t>Select the top matching chunks as context.</w:t></w:r></w:p><w:p><w:r><w:rPr><w:b/></w:rPr><w:t xml:space="preserve">4.  </w:t></w:r><w:r><w:t>Generate a response using either a simple extractive answer, an optional cloud AI provider, or a local LLM in later versions.</w:t></w:r></w:p><w:p><w:r><w:rPr><w:b/></w:rPr><w:t xml:space="preserve">5.  </w:t></w:r><w:r><w:t>Show references such as page number, paragraph, or chunk label so users know where the answer came from.</w:t></w:r></w:p><w:tbl><w:tblPr><w:tblStyle w:val="TableGrid"/><w:tblW w:type="auto" w:w="0"/><w:tblLook w:firstColumn="1" w:firstRow="1" w:lastColumn="0" w:lastRow="0" w:noHBand="0" w:noVBand="1" w:val="04A0"/></w:tblPr><w:tblGrid><w:gridCol w:w="10224"/></w:tblGrid><w:tr><w:tc><w:tcPr><w:tcW w:type="dxa" w:w="10224"/><w:shd w:fill="FFF2CC"/></w:tcPr><w:p><w:r/><w:r><w:rPr><w:b/><w:color w:val="184A78"/><w:sz w:val="22"/></w:rPr><w:t>MVP strategy</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="0"/></w:pPr><w:r><w:t>Start with reliable document capture, OCR, local storage, search, and chat UI. Add local LLM support only after the foundation is stable.</w:t></w:r></w:p></w:tc></w:tr></w:tbl><w:p/><w:p><w:pPr><w:pStyle w:val="Heading1"/></w:pPr><w:r><w:rPr><w:color w:val="184A78"/></w:rPr><w:t>10. Data Model</w:t></w:r></w:p><w:tbl><w:tblPr><w:tblStyle w:val="TableGrid"/><w:tblW w:type="auto" w:w="0"/><w:tblLook w:firstColumn="1" w:firstRow="1" w:lastColumn="0" w:lastRow="0" w:noHBand="0" w:noVBand="1" w:val="04A0"/></w:tblPr><w:tblGrid><w:gridCol w:w="3408"/><w:gridCol w:w="3408"/><w:gridCol w:w="3408"/></w:tblGrid><w:tr><w:tc><w:tcPr><w:tcW w:type="dxa" w:w="3408"/><w:shd w:fill="184A78"/></w:tcPr><w:p><w:r/><w:r><w:rPr><w:b/><w:color w:val="FFFFFF"/><w:sz w:val="18"/></w:rPr><w:t>Entity</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:type="dxa" w:w="3408"/><w:shd w:fill="184A78"/></w:tcPr><w:p><w:r/><w:r><w:rPr><w:b/><w:color w:val="FFFFFF"/><w:sz w:val="18"/></w:rPr><w:t>Fields</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:type="dxa" w:w="3408"/><w:shd w:fill="184A78"/></w:tcPr><w:p><w:r/><w:r><w:rPr><w:b/><w:color w:val="FFFFFF"/><w:sz w:val="18"/></w:rPr><w:t>Purpose</w:t></w:r></w:p></w:tc></w:tr><w:tr><w:tc><w:tcPr><w:tcW w:type="dxa" w:w="3408"/></w:tcPr><w:p><w:r/><w:r><w:rPr><w:b/><w:sz w:val="18"/></w:rPr><w:t>Document</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:type="dxa" w:w="3408"/></w:tcPr><w:p><w:r/><w:r><w:rPr><w:b w:val="0"/><w:sz w:val="18"/></w:rPr><w:t>id, title, sourceType, filePath, createdAt, updatedAt, tags</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:type="dxa" w:w="3408"/></w:tcPr><w:p><w:r/><w:r><w:rPr><w:b w:val="0"/><w:sz w:val="18"/></w:rPr><w:t>Represents one saved document.</w:t></w:r></w:p></w:tc></w:tr><w:tr><w:tc><w:tcPr><w:tcW w:type="dxa" w:w="3408"/></w:tcPr><w:p><w:r/